{
  "name": "saas-express-boilerplate",
  "version": "1.0.0",
  "description": "Enterprise-grade Express.js + MongoDB SaaS boilerplate",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "seed": "node scripts/seed.js",
    "migrate": "node scripts/migrate.js",
    "docs": "jsdoc -c jsdoc.config.json"
  },
  "keywords": ["express", "mongodb", "saas", "boilerplate", "enterprise"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.7",
    "handlebars": "^4.7.8",
    "stripe": "^14.10.0",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "bull": "^4.12.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "aws-sdk": "^2.1509.0",
    "uuid": "^9.0.0",
    "slugify": "^1.6.6",
    "moment": "^2.29.4",
    "lodash": "^4.17.21",
    "axios": "^1.6.2",
    "crypto": "^1.0.1",
    "express-async-errors": "^3.1.1",
    "mongoose-paginate-v2": "^1.7.4",
    "mongoose-aggregate-paginate-v2": "^1.0.6",
    "express-validator": "^7.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "socket.io": "^4.6.1",
    "cookie-parser": "^1.4.6",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-github2": "^0.1.12",
    "otp-generator": "^4.0.1",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "p-limit": "^3.1.0",
    "retry": "^0.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.1.1",
    "mongodb-memory-server": "^9.1.1",
    "@faker-js/faker": "^8.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathPattern": "tests/",
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageDirectory": "coverage"
  }
}
