# =============================================
# APPLICATION
# =============================================
NODE_ENV=development
PORT=3000
APP_NAME=SaaS App
APP_URL=http://localhost:3000
API_VERSION=v1
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================
# DATABASE
# =============================================
MONGODB_URI=mongodb://localhost:27017/saas_db
MONGODB_TEST_URI=mongodb://localhost:27017/saas_test_db
MONGODB_POOL_SIZE=10
MONGODB_TIMEOUT=30000

# =============================================
# REDIS
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# =============================================
# JWT
# =============================================
JWT_ACCESS_SECRET=your_super_secret_access_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=saas-app
JWT_AUDIENCE=saas-users

# =============================================
# ENCRYPTION
# =============================================
ENCRYPTION_KEY=your_32_char_encryption_key_here!!
ENCRYPTION_IV=your_16_char_iv!!

# =============================================
# EMAIL (SMTP)
# =============================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM_NAME=SaaS App
EMAIL_FROM_ADDRESS=noreply@saasapp.com

# =============================================
# AWS S3
# =============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_URL=https://your-bucket.s3.amazonaws.com
CDN_URL=https://cdn.yourdomain.com

# =============================================
# STRIPE
# =============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd

# =============================================
# OAUTH - GOOGLE
# =============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# =============================================
# OAUTH - GITHUB
# =============================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# =============================================
# RATE LIMITING
# =============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# =============================================
# LOGGING
# =============================================
LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# =============================================
# SESSIONS
# =============================================
SESSION_SECRET=your_session_secret_here
SESSION_MAX_AGE=86400000

# =============================================
# FILE UPLOADS
# =============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# =============================================
# QUEUE (BULL)
# =============================================
QUEUE_CONCURRENCY=5
QUEUE_LIMITER_MAX=10
QUEUE_LIMITER_DURATION=5000

# =============================================
# WEBHOOKS
# =============================================
WEBHOOK_SECRET=your_webhook_secret_here
